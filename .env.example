# ============================================================================
# gidek.net — environment variables template
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================================

# --- Public site --------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (local stack defaults — replace with cloud values in prod) ------
# After `supabase start`, run `supabase status` to get the current values.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — DO NOT prefix with NEXT_PUBLIC_. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# --- Gemini -------------------------------------------------------------------
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash
AI_EMBEDDING_MODEL=gemini-embedding-001
# Token fiyatlandırması — billing tier'a göre güncelle.
AI_INPUT_USD_PER_1M=0.10
AI_OUTPUT_USD_PER_1M=0.40
AI_DAILY_BUDGET_USD=2.00

# --- Mapbox (harita + reverse geocode) ----------------------------------------
# https://account.mapbox.com/access-tokens — prod'da URL whitelist sınırla.
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Cloudinary (admin görsel upload) -----------------------------------------
# Server-side credentials — admin'den deal/merchant resmi yüklenince Cloudinary'ye gider.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Cloudflare Turnstile (anon AI bot koruması) ------------------------------
# Get from https://dash.cloudflare.com/?to=/:account/turnstile
# Boş bırakılırsa Turnstile devre dışı — anon AI direkt geçer (dev için OK,
# production'da SETLE).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Resend (transactional email) ---------------------------------------------
# https://resend.com — RESEND_API_KEY yoksa email'ler stdout'a mock log basar.
RESEND_API_KEY=
# "Görünen ad <noreply@yourdomain.com>" — doğrulanmış sender domain gerekir.
EMAIL_FROM=

# --- Sentry (error tracking) --------------------------------------------------
# DSN yoksa SDK init no-op kalır; warning yok.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Source map upload için (CI'da set edilir):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- PWA push notifications ---------------------------------------------------
# Üret: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@gidek.net

# --- Wishlist share HMAC secret ----------------------------------------------
# Üret: openssl rand -base64 32
SHARE_TOKEN_SECRET=

# --- Admin allow-list ---------------------------------------------------------
# Comma-separated list of e-mails that get /admin access. Case-insensitive.
ADMIN_EMAILS=

# --- Upstash Redis (rate limit + semantic cache, opsiyonel) -------------------
# Boş bırakılırsa in-memory rate limit kullanılır (single-instance prod'da OK).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
