# ============================================================================
# gidek.net — environment variables template
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================================

# --- Public site --------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (local stack defaults — replace with cloud values in prod) ------
# After `supabase start`, run `supabase status` to get the current values.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — DO NOT prefix with NEXT_PUBLIC_. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# --- Gemini -------------------------------------------------------------------
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash
AI_EMBEDDING_MODEL=gemini-embedding-001

# --- Upstash Redis (rate limit + semantic cache) ------------------------------
# Create a free database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cloudflare Turnstile (bot protection) ------------------------------------
# Get from https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- AI safety knobs ----------------------------------------------------------
AI_DAILY_BUDGET_USD=20
AI_ANON_DAILY_LIMIT=2
AI_USER_DAILY_LIMIT=30

# --- Error tracking (optional in dev) -----------------------------------------
SENTRY_DSN=
